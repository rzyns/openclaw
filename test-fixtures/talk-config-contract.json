{
  "selectionCases": [
    {
      "id": "canonical_resolved_wins",
      "defaultProvider": "elevenlabs",
      "payloadValid": true,
      "expectedSelection": {
        "provider": "elevenlabs",
        "normalizedPayload": true,
        "voiceId": "voice-normalized",
        "apiKey": "xxxxx"
      },
      "talk": {
        "resolved": {
          "provider": "elevenlabs",
          "config": {
            "voiceId": "voice-normalized",
            "apiKey": "xxxxx"
          }
        },
        "provider": "elevenlabs",
        "providers": {
          "elevenlabs": {
            "voiceId": "voice-normalized",
            "apiKey": "xxxxx"
          }
        }
      }
    },
    {
      "id": "configured_secretref_with_resolved_string",
      "defaultProvider": "elevenlabs",
      "payloadValid": true,
      "expectedSelection": {
        "provider": "elevenlabs",
        "normalizedPayload": true,
        "voiceId": "voice-secretref",
        "apiKey": "resolved-elevenlabs-key"
      },
      "talk": {
        "resolved": {
          "provider": "elevenlabs",
          "config": {
            "voiceId": "voice-secretref",
            "apiKey": "resolved-elevenlabs-key"
          }
        },
        "provider": "elevenlabs",
        "providers": {
          "elevenlabs": {
            "voiceId": "voice-secretref",
            "apiKey": {
              "source": "env",
              "provider": "default",
              "id": "ELEVENLABS_API_KEY"
            }
          }
        }
      }
    },
    {
      "id": "normalized_missing_resolved",
      "defaultProvider": "elevenlabs",
      "payloadValid": false,
      "expectedSelection": null,
      "talk": {
        "provider": "elevenlabs",
        "providers": {
          "elevenlabs": {
            "voiceId": "voice-normalized"
          }
        },
        "voiceId": "voice-legacy"
      }
    },
    {
      "id": "provider_mismatch_missing_resolved",
      "defaultProvider": "elevenlabs",
      "payloadValid": false,
      "expectedSelection": null,
      "talk": {
        "provider": "acme",
        "providers": {
          "elevenlabs": {
            "voiceId": "voice-normalized"
          }
        }
      }
    },
    {
      "id": "ambiguous_providers_missing_resolved",
      "defaultProvider": "elevenlabs",
      "payloadValid": false,
      "expectedSelection": null,
      "talk": {
        "providers": {
          "acme": {
            "voiceId": "voice-acme"
          },
          "elevenlabs": {
            "voiceId": "voice-normalized"
          }
        }
      }
    },
    {
      "id": "legacy_payload_fallback",
      "defaultProvider": "elevenlabs",
      "payloadValid": true,
      "expectedSelection": {
        "provider": "elevenlabs",
        "normalizedPayload": true,
        "voiceId": "voice-legacy",
        "apiKey": "xxxxx"
      },
      "talk": {
        "provider": "elevenlabs",
        "resolved": {
          "provider": "elevenlabs",
          "config": {
            "voiceId": "voice-legacy",
            "apiKey": "xxxxx"
          }
        }
      }
    }
  ],
